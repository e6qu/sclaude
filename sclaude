#!/usr/bin/env bash
# sclaude: Run Claude Code in a Docker sandbox
# Supported shells: bash, zsh (via #!/usr/bin/env bash shebang)
# Supported platforms: macOS (Darwin), Linux

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
SCRIPT_NAME="sclaude"
TOOL_NAME="Claude Code"
TOOL_BIN="claude"
CONFIG_VOLUME="sclaude-config"
CONFIG_MOUNT="/sclaude-config"
CONFIG_ENV_NAME="CLAUDE_CONFIG_DIR"
YOLO_FLAG="--dangerously-skip-permissions"
WRAPPER_VERSION="2.2.0" # x-release-please-version
PROJECT_REPO="e6qu/sclaude"
RELEASE_CHECK_INTERVAL_SECONDS="86400"
ENGINE_CMD=""
ENGINE_TIMEOUT_SECONDS="${SAGENT_ENGINE_TIMEOUT_SECONDS:-10}"

IMAGE_REPO="sagent-sandbox"
MEMORY_LIMIT="4g"
CPU_LIMIT="2"
PIDS_LIMIT="100"

ROOTFS_VOLUME="sagent-rootfs"
NPM_VOLUME="sagent-npm"
PIP_VOLUME="sagent-pip"
APT_CACHE_VOLUME="sagent-apt-cache"
APT_LISTS_VOLUME="sagent-apt-lists"

HOST_UID=$(id -u)
HOST_GID=$(id -g)

TEMP_FILES=()
cleanup_temp() {
    for f in "${TEMP_FILES[@]+"${TEMP_FILES[@]}"}"; do
        rm -f "$f"
    done
}
trap cleanup_temp EXIT INT TERM HUP

portable_sha256() {
    if command -v sha256sum >/dev/null 2>&1; then
        sha256sum
    elif command -v shasum >/dev/null 2>&1; then
        shasum -a 256
    else
        echo "ERROR: neither sha256sum nor shasum found" >&2
        exit 1
    fi
}

run_with_timeout_quiet() {
    local seconds="$1"; shift
    local cmd_pid
    local timer_pid
    local rc

    "$@" >/dev/null 2>&1 &
    cmd_pid=$!
    (
        sleep "$seconds"
        kill "$cmd_pid" 2>/dev/null || true
    ) &
    timer_pid=$!

    if wait "$cmd_pid"; then
        rc=0
    else
        rc=$?
    fi
    kill "$timer_pid" 2>/dev/null || true
    wait "$timer_pid" 2>/dev/null || true
    return "$rc"
}

select_engine() {
    local requested="${SAGENT_CONTAINER_ENGINE:-}"
    local candidate

    if [ -n "$requested" ]; then
        if ! command -v "$requested" >/dev/null 2>&1; then
            echo "[$SCRIPT_NAME] ERROR: requested container engine not found: $requested" >&2
            exit 1
        fi
        if ! run_with_timeout_quiet "$ENGINE_TIMEOUT_SECONDS" "$requested" info; then
            echo "[$SCRIPT_NAME] ERROR: requested container engine is not responding: $requested" >&2
            exit 1
        fi
        ENGINE_CMD="$requested"
        return 0
    fi

    for candidate in docker podman; do
        if command -v "$candidate" >/dev/null 2>&1 && run_with_timeout_quiet "$ENGINE_TIMEOUT_SECONDS" "$candidate" info; then
            ENGINE_CMD="$candidate"
            return 0
        fi
    done

    echo "[$SCRIPT_NAME] ERROR: neither docker nor podman is available and responding." >&2
    echo "[$SCRIPT_NAME] Set SAGENT_CONTAINER_ENGINE=docker or SAGENT_CONTAINER_ENGINE=podman to choose explicitly." >&2
    exit 1
}

get_dockerfile_content() {
    cat <<'DOCKERFILE_END'
FROM ubuntu:24.04
ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y \
    curl git python3 python3-pip build-essential ca-certificates gnupg sudo \
    libsecret-1-0 dbus dbus-x11 gnome-keyring \
    && rm -rf /var/lib/apt/lists/*

RUN curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg \
        -o /usr/share/keyrings/githubcli-archive-keyring.gpg && \
    echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" \
        > /etc/apt/sources.list.d/github-cli.list && \
    apt-get update && apt-get install -y gh && rm -rf /var/lib/apt/lists/*

RUN curl -fsSL https://deb.nodesource.com/setup_24.x | bash - && \
    apt-get install -y nodejs && rm -rf /var/lib/apt/lists/*

RUN npm install -g @anthropic-ai/claude-code @openai/codex

ARG USER_UID=1000
ARG USER_GID=1000
RUN set -eux; \
    if getent group "${USER_GID}" >/dev/null; then \
        USER_GROUP="$(getent group "${USER_GID}" | cut -d: -f1)"; \
    else \
        groupadd -g "${USER_GID}" agent; \
        USER_GROUP=agent; \
    fi; \
    useradd -o -u "${USER_UID}" -g "${USER_GROUP}" -m -s /bin/bash agent; \
    echo 'agent ALL=(root) NOPASSWD: /usr/bin/apt-get, /usr/bin/apt, /usr/bin/dpkg' > /etc/sudoers.d/agent; \
    chmod 0440 /etc/sudoers.d/agent

RUN mkdir -p /workspace && chown agent /workspace

USER agent
WORKDIR /workspace
ENV HOME=/home/agent
ENV TMPDIR=/tmp
ENV NPM_CONFIG_PREFIX=/home/agent/.npm-global
ENV PATH="/home/agent/.npm-global/bin:/home/agent/.local/bin:${PATH}"
DOCKERFILE_END
}

get_version_hash() {
    {
        get_dockerfile_content
        echo "MEMORY_LIMIT=$MEMORY_LIMIT"
        echo "CPU_LIMIT=$CPU_LIMIT"
        echo "PIDS_LIMIT=$PIDS_LIMIT"
        echo "USER_UID=$HOST_UID"
        echo "USER_GID=$HOST_GID"
    } | portable_sha256 | cut -c1-8
}

VERSION_HASH=$(get_version_hash)
IMAGE_NAME="${IMAGE_REPO}:${VERSION_HASH}"

build_image() {
    local no_cache="${1:-}"
    local temp_dockerfile
    local build_timestamp
    local build_args=()

    if [ "$no_cache" = "--no-cache" ]; then
        echo "[$SCRIPT_NAME] Updating shared sandbox image (version: $VERSION_HASH)..." >&2
        build_args+=("--no-cache" "--pull")
    else
        echo "[$SCRIPT_NAME] Building shared sandbox image (version: $VERSION_HASH)..." >&2
    fi

    temp_dockerfile=$(mktemp)
    TEMP_FILES+=("$temp_dockerfile")
    get_dockerfile_content > "$temp_dockerfile"

    build_timestamp=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
    cat >> "$temp_dockerfile" <<EOF

USER root
RUN echo '{"version": "$VERSION_HASH", "build_timestamp": "$build_timestamp"}' > /sagent-metadata.json
USER agent
EOF

    "$ENGINE_CMD" build "${build_args[@]+"${build_args[@]}"}" \
        --build-arg USER_UID="$HOST_UID" \
        --build-arg USER_GID="$HOST_GID" \
        -t "$IMAGE_NAME" \
        -f "$temp_dockerfile" \
        "$SCRIPT_DIR"

    rm -f "$temp_dockerfile"

    echo "[$SCRIPT_NAME] Shared sandbox image ready" >&2
}

ensure_image() {
    if ! "$ENGINE_CMD" image inspect "$IMAGE_NAME" >/dev/null 2>&1; then
        echo "[$SCRIPT_NAME] Shared sandbox image not found (version: $VERSION_HASH), building..." >&2
        build_image
    fi
}

show_version() {
    local meta
    local tool_version

    echo "Script: $SCRIPT_NAME"
    echo "Sandbox image: $IMAGE_NAME"
    echo "Script version: $VERSION_HASH"
    if "$ENGINE_CMD" image inspect "$IMAGE_NAME" >/dev/null 2>&1; then
        tool_version=$("$ENGINE_CMD" run --rm "$IMAGE_NAME" "$TOOL_BIN" --version 2>/dev/null || echo "unknown")
        echo "$TOOL_NAME CLI: $tool_version"
        echo "Container metadata:"
        meta=$("$ENGINE_CMD" run --rm "$IMAGE_NAME" cat /sagent-metadata.json 2>/dev/null || true)
        if [ -n "$meta" ]; then
            if command -v python3 >/dev/null 2>&1; then
                printf '%s' "$meta" | python3 -m json.tool 2>/dev/null || printf '%s\n' "$meta"
            else
                printf '%s\n' "$meta"
            fi
        fi
    else
        echo "Container image not built yet"
    fi
}

cleanup_images() {
    echo "[$SCRIPT_NAME] Current version: $VERSION_HASH" >&2
    echo "[$SCRIPT_NAME] Removing old $IMAGE_REPO images..." >&2
    "$ENGINE_CMD" images "$IMAGE_REPO" --format "{{.Tag}}" \
        | { grep -vE "^($VERSION_HASH|latest)$" || true; } \
        | while read -r tag; do
        if [ -n "$tag" ]; then
            echo "  Removing $IMAGE_REPO:$tag" >&2
            "$ENGINE_CMD" rmi "$IMAGE_REPO:$tag" 2>&1 | grep -vE "^(Untagged|Deleted):" >&2 || true
        fi
    done
    echo "[$SCRIPT_NAME] Cleanup complete" >&2
}

show_volumes() {
    local volumes

    echo "[$SCRIPT_NAME] Docker volumes:"
    volumes=$("$ENGINE_CMD" volume ls --format "table {{.Name}}\t{{.Driver}}\t{{.Mountpoint}}")
    printf '%s\n' "$volumes" | grep -E "^(NAME|sagent-|sclaude-|scodex-)" || true
    printf "\n[%s] Volume sizes:\n" "$SCRIPT_NAME"
    "$ENGINE_CMD" system df -v | grep -E "sagent-|sclaude-|scodex-" || echo "  (volume size info not available)"
}

print_release_guidance() {
    local latest_tag="$1"

    echo "[$SCRIPT_NAME] New wrapper release available: $latest_tag (installed: v$WRAPPER_VERSION)" >&2
    echo "[$SCRIPT_NAME] Update/install scripts:" >&2
    echo "  sudo curl -fsSL https://github.com/$PROJECT_REPO/releases/latest/download/sclaude -o /usr/local/bin/sclaude" >&2
    echo "  sudo chmod +x /usr/local/bin/sclaude" >&2
    echo "  sudo curl -fsSL https://github.com/$PROJECT_REPO/releases/latest/download/scodex -o /usr/local/bin/scodex" >&2
    echo "  sudo chmod +x /usr/local/bin/scodex" >&2
}

# Fetch the latest release tag (e.g. "v2.4.0") or print empty on failure.
fetch_latest_release_tag() {
    if ! command -v curl >/dev/null 2>&1; then
        return 0
    fi
    curl -fsSL --max-time 5 "https://api.github.com/repos/$PROJECT_REPO/releases/latest" 2>/dev/null \
        | sed -n 's/.*"tag_name"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' | head -1 || true
}

# Returns 0 iff $1 is strictly greater than $2 under version sort. Empty strings sort lowest.
version_gt() {
    [ -n "$1" ] || return 1
    [ "$1" = "$2" ] && return 1
    [ "$(printf '%s\n%s\n' "$1" "$2" | sort -V | tail -1)" = "$1" ]
}

# Download the named release asset for $tag into $dest. Verifies the asset is a bash script
# that self-identifies as $asset at $tag. Returns 0 on success.
download_release_asset() {
    local tag="$1"
    local asset="$2"
    local dest="$3"
    local url="https://github.com/$PROJECT_REPO/releases/download/$tag/$asset"
    local expected_version="${tag#v}"

    if ! curl -fsSL --max-time 30 "$url" -o "$dest"; then
        echo "[$SCRIPT_NAME] Failed to download $url" >&2
        return 1
    fi
    if ! head -1 "$dest" | grep -q '^#!/usr/bin/env bash$'; then
        echo "[$SCRIPT_NAME] Downloaded $asset has unexpected shebang; refusing to install" >&2
        return 1
    fi
    if ! grep -qE "^SCRIPT_NAME=\"$asset\"\$" "$dest"; then
        echo "[$SCRIPT_NAME] Downloaded $asset does not declare SCRIPT_NAME=\"$asset\"; refusing to install" >&2
        return 1
    fi
    # WRAPPER_VERSION mismatch is a warning, not a hard reject: release-please cannot
    # always be relied on to bump the constant in the published asset, and blocking
    # self-update on that release-time bug would defeat the point of self-update.
    if ! grep -qE "^WRAPPER_VERSION=\"$expected_version\"( *#.*)?\$" "$dest"; then
        echo "[$SCRIPT_NAME] WARNING: downloaded $asset does not declare WRAPPER_VERSION=\"$expected_version\" (release packaging out of sync); install proceeding" >&2
    fi
    chmod +x "$dest"
}

# Atomically install $src to $dest by staging into the destination directory and renaming
# over the existing file. Uses sudo if the directory is not writable. Returns 0 on success.
install_wrapper_file() {
    local src="$1"
    local dest="$2"
    local dest_dir staged

    dest_dir="$(dirname "$dest")"
    staged="$dest_dir/.$(basename "$dest").$$.$(date +%s).tmp"

    if [ -w "$dest_dir" ]; then
        if ! cp "$src" "$staged" \
            || ! chmod 0755 "$staged" \
            || ! mv -f "$staged" "$dest"; then
            rm -f "$staged" 2>/dev/null || true
            return 1
        fi
    elif command -v sudo >/dev/null 2>&1; then
        echo "[$SCRIPT_NAME] $dest_dir is not writable; installing with sudo..." >&2
        if ! sudo cp "$src" "$staged" \
            || ! sudo chmod 0755 "$staged" \
            || ! sudo mv -f "$staged" "$dest"; then
            sudo rm -f "$staged" 2>/dev/null || true
            return 1
        fi
    else
        echo "[$SCRIPT_NAME] Cannot write $dest_dir and sudo is unavailable; skipping" >&2
        return 1
    fi
}

# Self-update the running wrapper (and its paired wrapper if present) to the latest release.
# Downloads both assets first; only installs after both downloads succeed. Re-execs the new
# wrapper to complete the update. Returns non-zero if any download or install step failed.
self_update_wrapper() {
    local latest_tag script_path script_dir paired_name paired_path
    local tmp_self tmp_paired=""

    if [ "${SAGENT_SKIP_SELF_UPDATE:-}" = "1" ]; then
        return 0
    fi

    script_path="$(realpath "${BASH_SOURCE[0]:-$0}" 2>/dev/null || printf '%s' "${BASH_SOURCE[0]:-$0}")"
    script_dir="$(dirname "$script_path")"
    case "$SCRIPT_NAME" in
        sclaude) paired_name="scodex" ;;
        scodex)  paired_name="sclaude" ;;
        *)       paired_name="" ;;
    esac
    paired_path=""
    if [ -n "$paired_name" ] && [ -f "$script_dir/$paired_name" ]; then
        paired_path="$script_dir/$paired_name"
    fi

    latest_tag=$(fetch_latest_release_tag)
    if [ -z "$latest_tag" ]; then
        echo "[$SCRIPT_NAME] Could not reach the releases API; skipping wrapper self-update" >&2
        return 0
    fi

    if ! version_gt "${latest_tag#v}" "$WRAPPER_VERSION"; then
        echo "[$SCRIPT_NAME] Wrapper at v$WRAPPER_VERSION is at or newer than $latest_tag; skipping self-update" >&2
        return 0
    fi

    echo "[$SCRIPT_NAME] Updating wrapper from v$WRAPPER_VERSION to $latest_tag..." >&2

    # Phase 1: download every asset to staging before touching the installed files.
    tmp_self=$(mktemp)
    TEMP_FILES+=("$tmp_self")
    if ! download_release_asset "$latest_tag" "$SCRIPT_NAME" "$tmp_self"; then
        print_release_guidance "$latest_tag"
        return 1
    fi
    if [ -n "$paired_path" ]; then
        tmp_paired=$(mktemp)
        TEMP_FILES+=("$tmp_paired")
        if ! download_release_asset "$latest_tag" "$paired_name" "$tmp_paired"; then
            print_release_guidance "$latest_tag"
            return 1
        fi
    fi

    # Phase 2: install. Each install is atomic per file via stage-then-rename. The two-file
    # install is best-effort all-or-nothing — if the second fails we report the partial state.
    if ! install_wrapper_file "$tmp_self" "$script_path"; then
        echo "[$SCRIPT_NAME] ERROR: failed to install new wrapper at $script_path" >&2
        print_release_guidance "$latest_tag"
        return 1
    fi
    if [ -n "$tmp_paired" ]; then
        if ! install_wrapper_file "$tmp_paired" "$paired_path"; then
            echo "[$SCRIPT_NAME] ERROR: $script_path is now $latest_tag but $paired_path failed to install" >&2
            echo "[$SCRIPT_NAME] Install $paired_name manually:" >&2
            echo "  sudo curl -fsSL https://github.com/$PROJECT_REPO/releases/download/$latest_tag/$paired_name -o $paired_path" >&2
            echo "  sudo chmod +x $paired_path" >&2
            return 1
        fi
        echo "[$SCRIPT_NAME] Paired wrapper at $paired_path is now $latest_tag" >&2
    fi
    echo "[$SCRIPT_NAME] Wrapper at $script_path is now $latest_tag" >&2

    # Phase 3: re-exec the freshly installed self so the image rebuild runs on current logic.
    echo "[$SCRIPT_NAME] Re-running update with the new wrapper..." >&2
    cleanup_temp
    SAGENT_SKIP_SELF_UPDATE=1 exec "$script_path" update
}

# Confirm a build succeeded by re-inspecting the image tag and verifying the inner tool runs.
verify_image_built() {
    local tool_version
    if ! "$ENGINE_CMD" image inspect "$IMAGE_NAME" >/dev/null 2>&1; then
        echo "[$SCRIPT_NAME] ERROR: build completed but $IMAGE_NAME was not tagged" >&2
        exit 1
    fi
    if ! tool_version=$("$ENGINE_CMD" run --rm "$IMAGE_NAME" "$TOOL_BIN" --version 2>&1); then
        echo "[$SCRIPT_NAME] ERROR: '$TOOL_BIN --version' failed inside the rebuilt image:" >&2
        printf '%s\n' "$tool_version" | sed 's/^/  /' >&2
        exit 1
    fi
    echo "[$SCRIPT_NAME] $TOOL_NAME CLI is now: $tool_version" >&2
}

check_release() {
    local explicit="${1:-false}"
    local cache_dir
    local cache_file
    local now
    local last_check
    local latest_tag

    if [ "${SAGENT_SKIP_RELEASE_CHECK:-}" = "1" ]; then
        return 0
    fi
    if ! command -v curl >/dev/null 2>&1; then
        return 0
    fi

    cache_dir="${XDG_CACHE_HOME:-${HOME}/.cache}/sagent"
    cache_file="$cache_dir/release-check"
    now=$(date +%s)
    last_check="0"
    if [ "$explicit" != "true" ] && [ -f "$cache_file" ]; then
        last_check=$(cat "$cache_file" 2>/dev/null || echo "0")
        if [ $((now - last_check)) -lt "$RELEASE_CHECK_INTERVAL_SECONDS" ]; then
            return 0
        fi
    fi

    if mkdir -p "$cache_dir" 2>/dev/null; then
        printf '%s\n' "$now" > "$cache_file" 2>/dev/null || true
    fi

    latest_tag=$(curl -fsSL --max-time 2 "https://api.github.com/repos/$PROJECT_REPO/releases/latest" 2>/dev/null | sed -n 's/.*"tag_name"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' | head -1 || true)
    if [ -z "$latest_tag" ]; then
        if [ "$explicit" = "true" ]; then
            echo "[$SCRIPT_NAME] Could not check latest release." >&2
        fi
        return 0
    fi

    if [ "${latest_tag#v}" != "$WRAPPER_VERSION" ]; then
        print_release_guidance "$latest_tag"
    elif [ "$explicit" = "true" ]; then
        echo "[$SCRIPT_NAME] Wrapper scripts are up to date ($latest_tag)." >&2
    fi
}

reset_volumes() {
    echo "[$SCRIPT_NAME] WARNING: This will delete all persisted sandbox data (credentials, packages, preferences, sessions)." >&2
    if [ "${SAGENT_ASSUME_YES:-}" != "1" ]; then
        if [ ! -t 0 ]; then
            echo "[$SCRIPT_NAME] ERROR: refusing to delete volumes non-interactively. Set SAGENT_ASSUME_YES=1 to override." >&2
            exit 1
        fi
        echo "[$SCRIPT_NAME] Press Ctrl+C to cancel, or Enter to continue..." >&2
        read -r
    fi
    echo "[$SCRIPT_NAME] Removing Docker volumes..." >&2
    "$ENGINE_CMD" volume rm \
        sclaude-config scodex-config \
        "$ROOTFS_VOLUME" "$NPM_VOLUME" "$PIP_VOLUME" "$APT_CACHE_VOLUME" "$APT_LISTS_VOLUME" \
        2>/dev/null || true
    echo "[$SCRIPT_NAME] Reset complete. Volumes will be recreated on next run." >&2
}

parse_args() {
    WRAPPER_COMMAND=""
    YOLO=true
    ARGS=()
    for arg in "$@"; do
        case "$arg" in
            --yolo)
                YOLO=true
                ;;
            --no-yolo)
                YOLO=false
                ;;
            build|--build|update|check-update|cleanup|version|--version|--version-info|volumes|reset)
                if [ -z "$WRAPPER_COMMAND" ] && [ "${#ARGS[@]}" -eq 0 ]; then
                    WRAPPER_COMMAND="$arg"
                else
                    ARGS+=("$arg")
                fi
                ;;
            *)
                ARGS+=("$arg")
                ;;
        esac
    done
}

create_volumes() {
    local existing v
    existing=$("$ENGINE_CMD" volume ls --format '{{.Name}}' 2>/dev/null || true)
    for v in "$CONFIG_VOLUME" "$ROOTFS_VOLUME" "$NPM_VOLUME" "$PIP_VOLUME" "$APT_CACHE_VOLUME" "$APT_LISTS_VOLUME"; do
        if ! printf '%s\n' "$existing" | grep -qFx "$v"; then
            "$ENGINE_CMD" volume create "$v" >/dev/null 2>&1 || true
        fi
    done
}

read_credentials() {
    CREDS=""
    if [ "$(uname -s)" = "Darwin" ]; then
        CREDS=$(security find-generic-password -s "Claude Code-credentials" -w 2>/dev/null || true)
    else
        for cred_path in \
            "${HOME}/.claude/.credentials.json" \
            "${XDG_CONFIG_HOME:-${HOME}/.config}/claude-code/credentials.json"; do
            if [ -f "$cred_path" ]; then
                CREDS=$(cat "$cred_path" 2>/dev/null || true)
                break
            fi
        done
    fi
}

sync_state() {
    read_credentials

    # shellcheck disable=SC2016
    printf '%s' "$CREDS" | "$ENGINE_CMD" run --rm -i --user root \
        -v "$CONFIG_VOLUME":/vol-config \
        -v "$ROOTFS_VOLUME":/vol-rootfs \
        -v "$NPM_VOLUME":/vol-npm \
        -v "$PIP_VOLUME":/vol-pip \
        -v "$APT_CACHE_VOLUME":/vol-apt-cache \
        -v "$APT_LISTS_VOLUME":/vol-apt-lists \
        "$IMAGE_NAME" \
        bash -c '
            TARGET_UID='"$HOST_UID"'
            TARGET_GID='"$HOST_GID"'
            for d in /vol-config /vol-rootfs /vol-npm /vol-pip; do
                if [ "$(stat -c %u "$d" 2>/dev/null)" != "$TARGET_UID" ]; then
                    chown -R "$TARGET_UID:$TARGET_GID" "$d"
                fi
            done
            mkdir -p /vol-apt-cache/archives/partial /vol-apt-lists/partial
            chown -R root:root /vol-apt-cache /vol-apt-lists
            chmod 755 /vol-apt-cache /vol-apt-cache/archives /vol-apt-lists
            CREDS=$(cat)
            if [ -n "$CREDS" ]; then
                if printf "%s" "$CREDS" | python3 -m json.tool >/dev/null 2>&1; then
                    printf "%s" "$CREDS" > /vol-config/.credentials.json
                    chown "$TARGET_UID:$TARGET_GID" /vol-config/.credentials.json
                    chmod 600 /vol-config/.credentials.json
                else
                    echo "['"$SCRIPT_NAME"'] Warning: credentials found but appear malformed, skipping sync" >&2
                fi
            fi
        ' || echo "[$SCRIPT_NAME] Warning: credential sync failed (non-fatal)" >&2
}

validate_workspace() {
    WORKSPACE_PATH="$(pwd)"
    if [[ "$WORKSPACE_PATH" == *:* ]]; then
        echo "[$SCRIPT_NAME] ERROR: workspace path contains a colon, which conflicts with Docker volume syntax:" >&2
        echo "  $WORKSPACE_PATH" >&2
        echo "[$SCRIPT_NAME] Please run from a directory without colons in its path." >&2
        exit 1
    fi
}

build_docker_tty_flags() {
    DOCKER_TTY_FLAGS=()
    if [ -t 0 ]; then
        DOCKER_TTY_FLAGS+=("-it")
    else
        DOCKER_TTY_FLAGS+=("-i")
    fi
}

run_tool() {
    local tool_args=()

    if [ "$YOLO" = true ]; then
        tool_args=("$YOLO_FLAG" "${ARGS[@]+"${ARGS[@]}"}")
    else
        tool_args=("${ARGS[@]+"${ARGS[@]}"}")
    fi

    exec "$ENGINE_CMD" run "${DOCKER_TTY_FLAGS[@]}" --rm \
        -v "$WORKSPACE_PATH:$WORKSPACE_PATH:rw" \
        -v "$CONFIG_VOLUME:$CONFIG_MOUNT:rw" \
        -v "$ROOTFS_VOLUME:/home/agent:rw" \
        -v "$NPM_VOLUME:/home/agent/.npm-global:rw" \
        -v "$PIP_VOLUME:/home/agent/.local:rw" \
        -v "$APT_CACHE_VOLUME:/var/cache/apt:rw" \
        -v "$APT_LISTS_VOLUME:/var/lib/apt/lists:rw" \
        -w "$WORKSPACE_PATH" \
        --memory="$MEMORY_LIMIT" \
        --cpus="$CPU_LIMIT" \
        --pids-limit="$PIDS_LIMIT" \
        --tmpfs /tmp:rw,nosuid,size=1g \
        --cap-drop=ALL \
        --cap-add=CHOWN \
        --cap-add=DAC_OVERRIDE \
        --cap-add=FOWNER \
        --cap-add=FSETID \
        --cap-add=SETGID \
        --cap-add=SETUID \
        --cap-add=SYS_CHROOT \
        --cap-add=NET_BIND_SERVICE \
        --network bridge \
        --ulimit nofile=8192:8192 \
        -e "$CONFIG_ENV_NAME=$CONFIG_MOUNT" \
        -e ANTHROPIC_API_KEY \
        -e ANTHROPIC_AUTH_TOKEN \
        -e ANTHROPIC_BASE_URL \
        -e ANTHROPIC_MODEL \
        -e CLAUDE_CODE_OAUTH_TOKEN \
        -e "TERM=${TERM:-xterm-256color}" \
        "$IMAGE_NAME" \
        "$TOOL_BIN" "${tool_args[@]+"${tool_args[@]}"}"
}

parse_args "$@"

if [ "$WRAPPER_COMMAND" = "check-update" ]; then
    check_release true
    exit 0
fi

select_engine

case "$WRAPPER_COMMAND" in
    update)
        if ! self_update_wrapper; then
            echo "[$SCRIPT_NAME] ERROR: wrapper self-update failed; not rebuilding image." >&2
            exit 1
        fi
        build_image --no-cache
        verify_image_built
        exit 0
        ;;
    build|--build)
        build_image
        exit 0
        ;;
    cleanup)
        cleanup_images
        exit 0
        ;;
    version|--version|--version-info)
        show_version
        exit 0
        ;;
    volumes)
        show_volumes
        exit 0
        ;;
    reset)
        reset_volumes
        exit 0
        ;;
    "")
        ;;
esac

ensure_image
check_release false
create_volumes
sync_state
validate_workspace
build_docker_tty_flags
run_tool
